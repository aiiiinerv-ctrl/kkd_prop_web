# SQLite file path (relative to project root). Swap to a postgres:// URL later if migrating.
DATABASE_URL="file:./prisma/dev.db"

# Auth.js — generate with: openssl rand -base64 33
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# First admin account, created by `npx prisma db seed`
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Admin"

# File storage: "local" writes under STORAGE_ROOT ("s3" not implemented yet)
STORAGE_DRIVER="local"
STORAGE_ROOT="./storage"

# Email notifications via Resend — all three required to enable the channel
RESEND_API_KEY=""
NOTIFY_EMAIL_FROM="KKD Solar <noreply@example.com>"
NOTIFY_EMAIL_TO="admin@example.com"

# LINE notifications via LINE Messaging API (push through your LINE OA).
# LINE_NOTIFY_TO = comma-separated LINE userIds or a group id. Both required to enable.
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_NOTIFY_TO=""

# Public site URL — used in notification deep links and sitemap
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
