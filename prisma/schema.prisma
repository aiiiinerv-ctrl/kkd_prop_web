generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  EDITOR
}

enum LeadType {
  QUOTE
  SURVEY
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

enum BuildingType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
}

enum TimeSlot {
  MORNING
  AFTERNOON
}

enum PaymentStatus {
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum ServiceKind {
  SYSTEM
  MAINTENANCE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
}

model AdminUser {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(EDITOR)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model PromoChannel {
  id        String  @id @default(cuid())
  slug      String  @unique
  nameTh    String
  nameEn    String
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  leads     Lead[]
}

model Lead {
  id              String         @id @default(cuid())
  type            LeadType
  status          LeadStatus     @default(NEW)
  name            String
  phone           String
  lineId          String?
  province        String
  buildingType    BuildingType
  avgMonthlyBill  Int?
  locale          String         @default("th")
  sourceChannelId String?
  sourceChannel   PromoChannel?  @relation(fields: [sourceChannelId], references: [id])
  notes           String?
  booking         SurveyBooking?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status, createdAt])
}

model SurveyBooking {
  id             String        @id @default(cuid())
  leadId         String        @unique
  lead           Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  address        String
  preferredDate  DateTime
  timeSlot       TimeSlot
  amountThb      Int           @default(199)
  paymentSlipKey String
  paymentStatus  PaymentStatus @default(PENDING_REVIEW)
}

model Service {
  id            String      @id @default(cuid())
  slug          String      @unique
  kind          ServiceKind
  titleTh       String
  titleEn       String
  descriptionTh String
  descriptionEn String
  featuresTh    Json?
  featuresEn    Json?
  imageKey      String?
  sortOrder     Int         @default(0)
  isPublished   Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Package {
  id                 String   @id @default(cuid())
  slug               String   @unique
  nameTh             String
  nameEn             String
  sizeKw             Float
  priceThb           Int
  isPopular          Boolean  @default(false)
  suitableTh         String
  suitableEn         String
  featuresTh         Json
  featuresEn         Json
  seasonalProduction Json
  imageKey           String?
  sortOrder          Int      @default(0)
  isPublished        Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PortfolioProject {
  id            String        @id @default(cuid())
  slug          String        @unique
  titleTh       String
  titleEn       String
  descriptionTh String
  descriptionEn String
  category      BuildingType
  province      String
  systemSizeKw  Float
  imageKeys     Json
  completedAt   DateTime?
  sortOrder     Int           @default(0)
  isPublished   Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  testimonials  Testimonial[]

  @@index([category, isPublished])
}

model Testimonial {
  id           String           @id @default(cuid())
  customerName String
  quoteTh      String
  quoteEn      String
  role         String?
  province     String?
  photoKey     String?
  projectId    String?
  project      PortfolioProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sortOrder    Int              @default(0)
  isPublished  Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([isPublished, sortOrder])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  actor      AdminUser   @relation(fields: [actorId], references: [id])
  action     AuditAction
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
